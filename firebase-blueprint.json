{
  "entities": {
    "SensorReading": {
      "title": "Sensor Reading",
      "description": "Real-time environmental data from ground sensors.",
      "type": "object",
      "properties": {
        "region": { "type": "string", "description": "The geographical region." },
        "reservoir_level": { "type": "number", "description": "Percentage of reservoir capacity." },
        "groundwater_level": { "type": "number", "description": "Groundwater level in meters." },
        "rainfall": { "type": "number", "description": "Rainfall in mm." },
        "river_flow": { "type": "number", "description": "River flow in m3/s." },
        "soil_moisture": { "type": "number", "description": "Soil moisture percentage." },
        "temperature": { "type": "number", "description": "Ambient temperature in Celsius." },
        "humidity": { "type": "number", "description": "Humidity percentage." },
        "evaporation": { "type": "number", "description": "Evaporation rate." },
        "timestamp": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp." }
      },
      "required": ["region", "reservoir_level", "timestamp"]
    },
    "Forecast": {
      "title": "Water Forecast",
      "description": "Predictive water availability forecast.",
      "type": "object",
      "properties": {
        "region": { "type": "string" },
        "forecast": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "month": { "type": "string" },
              "water_availability": { "type": "number" },
              "risk": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] }
            }
          }
        },
        "summary": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Alert": {
      "title": "Risk Alert",
      "description": "Drought or flood risk alert.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["DROUGHT", "FLOOD", "ANOMALY"] },
        "region": { "type": "string" },
        "severity": { "type": "string", "enum": ["LOW", "WARNING", "CRITICAL"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/sensors/{sensorId}": {
      "schema": "SensorReading",
      "description": "Collection of real-time sensor readings."
    },
    "/forecasts/{forecastId}": {
      "schema": "Forecast",
      "description": "Collection of regional water forecasts."
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Collection of active risk alerts."
    }
  }
}
